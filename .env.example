# Alpha Vantage — stock/market data MCP (global ~/.cursor/mcp.json)
# Get a free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Google Cloud OAuth — Web application client (Phase 1)
# Copy to .env in project root (or set in system environment). Never commit .env.
#
# GCP Console: Google Auth Platform > Clients > Create Client > Web application
# Redirect URI (required for Cursor): cursor://anysphere.cursor-mcp/oauth/callback

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email to use for Google sign-in (auth.py login hint)
GOOGLE_OAUTH_EMAIL=dhulipudialekhya@gmail.com

# Optional — document which GCP project you enabled APIs on (not a secret)
GOOGLE_CLOUD_PROJECT_ID=

# --- Railway deployment (see docs/deployment-railway.md) ---
# Public URL of your Railway MCP service, e.g. https://weekly-pulse-production.up.railway.app
RAILWAY_MCP_URL=

# Optional bearer token if you add auth middleware in front of /mcp
MCP_SERVER_API_KEY=

# Data directory inside container (default /app/data — mount Railway Volume here)
DATA_DIR=/app/data

# Server bind (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=8080
