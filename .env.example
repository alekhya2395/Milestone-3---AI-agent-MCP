# Google Cloud OAuth — Web application client (Phase 1)
# Groq — LLM for theme analysis & pulse (Phase 3)
# Get a key: https://console.groq.com/
GROQ_API_KEY=

# Alpha Vantage — stock/market data MCP (global ~/.cursor/mcp.json)
# Get a free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Google Cloud OAuth — Web application client (Phase 1)
# Copy to .env in project root (or set in system environment). Never commit .env.
#
# GCP Console: Google Auth Platform > Clients > Create Client > Web application
# Redirect URI (required for Cursor): cursor://anysphere.cursor-mcp/oauth/callback

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional — document which GCP project you enabled APIs on (not a secret)
GOOGLE_CLOUD_PROJECT_ID=

# Product — Milestone 1 app (default: Groww)
PRODUCT_NAME=Groww
APP_STORE_ID=1404871703
PLAY_PACKAGE=com.nextbillion.groww
PLAY_COUNTRY=in
APP_STORE_COUNTRIES=in,us

# Phase 4 — Google Docs via Drive MCP
# Optional — folder for new weekly Docs (DEC-008: new Doc each run)
#   https://drive.google.com/drive/folders/PASTE_THIS_PART
GOOGLE_DRIVE_FOLDER_ID=

# Optional — existing Doc ID for read-back smoke test only (--verify-only)
#   https://docs.google.com/document/d/PASTE_THIS_PART/edit
GOOGLE_DOC_ID=

# Phase 5 — Gmail draft via Gmail MCP
# Recipient for create_draft (plain email, e.g. you@gmail.com)
GMAIL_DRAFT_TO=

# Scheduler — review window for weekly cron (default 10 weeks)
REVIEW_WEEKS=10
